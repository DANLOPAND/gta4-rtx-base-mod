            int[] faceVertexCounts = []
            int[] faceVertexIndices = []
            rel material:binding = </RootNode/Looks/conc_material> (
                bindMaterialAs = "weakerThanDescendants"
            )
            normal3f[] normals = [] (
                interpolation = "faceVarying"
            )
            point3f[] points = []
            rel proxyPrim
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "curve_inst"
        }

