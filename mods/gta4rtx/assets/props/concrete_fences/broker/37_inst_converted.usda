#usda 1.0
(
    defaultPrim = "RootNode"
    upAxis = "Z"
)

def Xform "RootNode" (
    kind = "model"
)
{
    def Scope "Looks"
    {
        def Material "conc_material" (
            prepend references = @../../../../materials/AperturePBR_Opacity.usda@</Looks/mat_AperturePBR_Opacity>
        )
        {
            token outputs:surface.connect = </RootNode/Looks/conc_material/Shader.outputs:out>

            over "Shader"
            {
                color3f inputs:diffuse_color_constant = (0.8, 0.8, 0.8)
            }
        }
    }

    def Xform "curve_inst"
    {
        def Mesh "curve_inst_mesh" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
