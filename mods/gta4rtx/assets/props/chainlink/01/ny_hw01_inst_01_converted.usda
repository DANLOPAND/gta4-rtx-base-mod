                bindMaterialAs = "weakerThanDescendants"
            )
            normal3f[] normals = [] (
                interpolation = "faceVarying"
            )
            point3f[] points = []
            rel proxyPrim
            uniform token subdivisionScheme = "none"
            custom string userProperties:blender:data_name = "Instancer01_Fence"
        }

