#usda 1.0
(
    defaultPrim = "RootNode"
    upAxis = "Z"
)

def Xform "RootNode" (
    kind = "model"
)
{
    def Scope "Looks"
    {
        def Material "chainlink_light" (
            prepend references = @../../../../materials/AperturePBR_Opacity.usda@</Looks/mat_AperturePBR_Opacity>
        )
        {
            token outputs:surface.connect = </RootNode/Looks/chainlink_light/Shader.outputs:out>

            over "Shader"
            {
                color3f inputs:diffuse_color_constant = (0.8, 0.8, 0.8)
            }
        }
    }

